{
  "appId": "org.bkcb6.app",
  "appName": "CB6 & Beyond",
  "webDir": ".",
  "server": {
    "url": "https://bkcb6.app",
    "cleartext": false
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#132D65",
    "statusBarStyle": "light"
  },
  "android": {
    "backgroundColor": "#132D65",
    "statusBarStyle": "light"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 1500,
      "backgroundColor": "#132D65",
      "iosSpinnerStyle": "small",
      "androidSplashResourceName": "splash",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#132D65"
    }
  }
}
